@page "/AddProjectMember/{ProjectId:int}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject NavigationManager Navigation
@inject DialogService DialogService

<Message @ref="notificationComponent" />

<div class="container-fluid">

    <!-- ✅ SAME HEADER -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-header">
                <div class="row align-items-center">
                    <div class="col-lg-6">
                        <div class="d-flex align-items-center">
                            <div class="header-icon me-4">
                                <div class="icon-circle bg-gradient-primary">
                                    <i class="fas fa-users text-white"></i>
                                </div>
                            </div>
                            <div class="header-content">
                                <h1 class="display-6 fw-bold mb-2">@ProjectName</h1>
                                
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-12">
                        <div class="header-description">
                            <p class="lead mb-0">
                                <i class="fas fa-info-circle me-2"></i>
                                Manage all members from here.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ✅ MULTI SELECT -->
    <div class="card p-3 shadow-sm mb-3">
        <RadzenDropDown TValue="IEnumerable<int>"
                        @bind-Value="SelectedMemberIds"
                        Data="@AvailableMembers"
                        TextProperty="Name"
                        ValueProperty="Id"
                        Placeholder="Search Members..."
                        Multiple="true"
                        AllowFiltering="true"
                        AllowClear="true"
                        Chips="true"
                        Style="width:100%" />
    </div>

    <!-- ✅ ACTION BUTTON -->
    <div class="mt-3">
        <RadzenButton Text="Save"
                      Icon="save"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="Save"
                      Class="me-2" />

        <RadzenButton Text="Cancel"
                      ButtonStyle="ButtonStyle.Light"
                      Click="Cancel" />
    </div>

</div>

<style>
   
    .dashboard-header {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

    .header-meta .meta-item {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background: rgba(0,0,0,0.03);
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .header-description {
        padding-top: 1rem;
        border-top: 1px solid rgba(0,0,0,0.1);
        color: #4a5568;
    }
</style>


@code {
    [Parameter]
    public int ProjectId { get; set; }

    private Message notificationComponent;

    private IList<UniqueMemberDTO> AvailableMembers = new List<UniqueMemberDTO>();
    private IEnumerable<int> SelectedMemberIds = new List<int>();

    [Inject]
    private IProject m_Project { get; set; }

    
    private string ProjectName { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AvailableMembers = await m_Project.GetUniqueProjectMembers(ProjectId);
        ProjectName = m_Project.GetProjectName(ProjectId);
    }

    private async Task Save()
    {
        if (!SelectedMemberIds.Any())
        {
            notificationComponent.Show("Warning", "Please select at least one member", NotificationSeverity.Warning);
            return;
        }

        await m_Project.AddProjectMembers(ProjectId, SelectedMemberIds.ToList());

        notificationComponent.Show("Success", "Members added successfully", NotificationSeverity.Success);

        Navigation.NavigateTo("/projects");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/projects");
    }
}