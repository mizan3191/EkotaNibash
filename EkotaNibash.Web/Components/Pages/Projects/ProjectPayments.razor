@page "/ProjectPayments/{ProjectId:int}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject IProject m_Project
@inject NavigationManager Navigation
@inject DialogService DialogService

<Message @ref="notificationComponent" />

<PageTitle>Project Payments</PageTitle>

<div class="container-fluid">

    <!-- ✅ HEADER -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-header">
                <div class="row align-items-center">

                    <div class="col-lg-6">
                        <div class="d-flex align-items-center">

                            <div class="header-icon me-4">
                                <div class="icon-circle bg-gradient-success">
                                    <i class="fas fa-money-bill-wave text-white"></i>
                                </div>
                            </div>

                            <div>
                                <h1 class="display-6 fw-bold mb-2">Project Payments</h1>

                                <div class="header-meta d-flex gap-3">

                                    <div class="meta-item">
                                        Member Invest:
                                        <strong>@TotalMembersAmount.ToString("0.00")</strong>
                                    </div>

                                    <div class="meta-item">
                                        Client Paid:
                                        <strong>@TotalClientAmount.ToString("0.00")</strong>
                                    </div>

                                    <div class="meta-item">
                                        <i class="fas fa-home text-success me-1"></i>
                                        <span>@ProjectName</span>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 text-end">

                        <RadzenButton Text="Add Payment"
                                      Icon="add_circle"
                                      Size="ButtonSize.Large"
                                      Click="AddPayment"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Class="me-2" />

                        <RadzenButton Text="Back"
                                      Icon="arrow_back"
                                      Size="ButtonSize.Large"
                                      Click="Back"
                                      ButtonStyle="ButtonStyle.Light" />

                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- ✅ MEMBER GRID -->
            <div class="card row mt-5">
                <div class="d-flex align-items-center mb-3 px-3 py-2 bg-light border-start border-danger border-4 rounded">
                    <i class="bi bi-trash-fill text-danger fs-4 me-2"></i>
                    <h5 class="mb-0 fw-semibold text-dark">Member Invest</h5>
                </div>
                <div class="col-12">
            <RadzenDataGrid Data="@MembersInvest" TItem="ProjectPayment" AllowPaging="true">

                <Columns>

                    <RadzenDataGridColumn Title="Date">
                        <Template Context="p">@p.DateFormatted</Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn Title="Member">
                        <Template Context="p">@p.EkotaMember?.Name</Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn Title="Amount">
                        <Template Context="p">
                            <b class="text-success">@p.Amount.ToString("0.00")</b>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn Property="Description" Title="Description" />

                    <RadzenDataGridColumn Title="Actions" Width="100px">
                        <Template Context="p">

                            <RadzenButton Icon="edit"
                                          ButtonStyle="ButtonStyle.Warning"
                                          Click="() => Edit(p.Id)"
                                          Size="ButtonSize.Small" />

                            <RadzenButton Icon="delete"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Click="() => Delete(p.Id)"
                                          Size="ButtonSize.Small" />

                        </Template>
                    </RadzenDataGridColumn>

                </Columns>
            </RadzenDataGrid>

        </div>
    </div>

    <!-- ✅ CLIENT GRID -->
            <div class="card row mt-5">
                <div class="d-flex align-items-center mb-3 px-3 py-2 bg-light border-start border-danger border-4 rounded">
                    <i class="bi bi-trash-fill text-danger fs-4 me-2"></i>
            <h5 class="mb-0 fw-semibold text-dark">Client Payments</h5>
                </div>
                <div class="col-12">
            <RadzenDataGrid Data="@ClientPayments" TItem="ProjectPayment" AllowPaging="true">

                <Columns>

                    <RadzenDataGridColumn Title="Date">
                        <Template Context="p">@p.DateFormatted</Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn Title="Amount">
                        <Template Context="p">
                            <b class="text-success">@p.Amount.ToString("0.00")</b>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn Property="Description" Title="Description" />

                    <RadzenDataGridColumn Title="Actions" Width="100px">
                        <Template Context="p">

                            <RadzenButton Icon="edit"
                                          ButtonStyle="ButtonStyle.Warning"
                                          Click="() => Edit(p.Id)"
                                          Size="ButtonSize.Small" />

                            <RadzenButton Icon="delete"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Click="() => Delete(p.Id)"
                                          Size="ButtonSize.Small" />

                        </Template>
                    </RadzenDataGridColumn>

                </Columns>
            </RadzenDataGrid>

        </div>
    </div>

</div>

<!-- ✅ POPUP -->
@if (showModal)
{
    <div class="modal" style="display:block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h4>@(payment.Id > 0 ? "Edit Payment" : "Add Payment")</h4>
                </div>

                <EditForm Model="@payment" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="modal-body">

                        <div class="row g-3">

                            <!-- DATE -->
                            <div class="col-md-4">
                                <RadzenLabel Text="Date *" />
                                <RadzenDatePicker @bind-Value="payment.Date" Class="w-100" />
                            </div>

                            <!-- TYPE -->
                            <div class="col-md-4">
                                <RadzenLabel Text="Payment Type *" />
                                <RadzenDropDown Data="@paymentTypes"
                                                @bind-Value="payment.ProjectPaymentType"
                                                TextProperty="Text"
                                                ValueProperty="Value"
                                                Change="OnPaymentTypeChange"
                                                Class="w-100" />
                            </div>

                            <!-- AMOUNT -->
                            <div class="col-md-4">
                                <RadzenLabel Text="Amount *" />
                                <RadzenNumeric @bind-Value="payment.Amount" Class="w-100" />
                            </div>

                            <!-- MEMBER -->
                            @if (showMemberDropdown)
                            {
                                <div class="col-md-6">
                                    <RadzenLabel Text="Member *" />
                                    <RadzenDropDown Data="@members"
                                                    @bind-Value="payment.EkotaMemberId"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    Class="w-100" />

                                    @if (payment.EkotaMemberId == null)
                                    {
                                        <div class="text-danger">Member required</div>
                                    }
                                </div>
                            }

                            <!-- DESCRIPTION -->
                            <div class="col-12">
                                <RadzenLabel Text="Description" />
                                <RadzenTextArea @bind-Value="payment.Description" Class="w-100" />
                            </div>

                        </div>

                    </div>

                    <div class="modal-footer">
                        <RadzenButton Text="Save"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Type="submit"
                                      Class="me-2" />

                        <RadzenButton Text="Cancel"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="CloseModal" />
                    </div>

                </EditForm>

            </div>
        </div>
    </div>
}

<!-- ✅ CSS -->
<style>
    .dashboard-header {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bg-gradient-success {
        background: linear-gradient(135deg, #11998e, #38ef7d);
    }

    .meta-item {
        padding: 6px 12px;
        background: #f3f3f3;
        border-radius: 6px;
    }
</style>

@code {

    [Parameter] public int ProjectId { get; set; }

    private IList<ProjectPayment> payments = new List<ProjectPayment>();
    private IList<ProjectPayment> MembersInvest = new List<ProjectPayment>();
    private IList<ProjectPayment> ClientPayments = new List<ProjectPayment>();

    private IList<Lov> members = new List<Lov>();
    private IList<dynamic> paymentTypes = new List<dynamic>();

    private ProjectPayment payment = new();
    private bool showModal = false;
    private bool showMemberDropdown = false;
    private string ProjectName = string.Empty;

    private Message notificationComponent;

    private double TotalClientAmount => ClientPayments.Sum(x => x.Amount);
    private double TotalMembersAmount => MembersInvest.Sum(x => x.Amount);

    protected override async Task OnInitializedAsync()
    {
        LoadTypes();
        members = await m_Project.GetAllProjectMembers(ProjectId);
        await LoadData();
        ProjectName = m_Project.GetProjectName(ProjectId);
    }

    private async Task LoadData()
    {
        payments = await m_Project.GetAllProjectPayments(ProjectId, null, null);

        MembersInvest = payments.Where(x => x.ProjectPaymentType == ProjectPaymentType.Member).ToList();
        ClientPayments = payments.Where(x => x.ProjectPaymentType == ProjectPaymentType.Client).ToList();
    }

    private void AddPayment()
    {
        payment = new ProjectPayment
        {
            ProjectId = ProjectId,
            Date = DateTime.Today
        };

        SetMemberVisibility();
        showModal = true;
    }

    private void Edit(int id)
    {
        payment = m_Project.GetProjectPayment(id);
        SetMemberVisibility();
        showModal = true;
    }

    private void OnPaymentTypeChange(object value)
    {
        SetMemberVisibility();
    }

    private void SetMemberVisibility()
    {
        showMemberDropdown = payment.ProjectPaymentType == ProjectPaymentType.Member;

        if (!showMemberDropdown)
            payment.EkotaMemberId = null;
    }

    private void LoadTypes()
    {
        paymentTypes = Enum.GetValues(typeof(ProjectPaymentType))
            .Cast<ProjectPaymentType>()
            .Select(x => new { Value = x, Text = x.ToString() })
            .ToList<dynamic>();
    }

    private async Task HandleSubmit()
    {
        if (showMemberDropdown && payment.EkotaMemberId == null)
        {
            notificationComponent.Show("Error", "Select member", NotificationSeverity.Error);
            return;
        }

        if (payment.Id > 0)
            m_Project.ProjectPaymentUpdate(payment);
        else
            m_Project.ProjectPaymentCreate(payment);

        showModal = false;
        await LoadData();

        notificationComponent.Show("Success", "Saved", NotificationSeverity.Success);
    }

    private async Task Delete(int id)
    {
        var confirm = await DialogService.Confirm("Delete?", "Confirm");

        if (confirm == true)
        {
            m_Project.ProjectPaymentDelete(id);
            await LoadData();
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void Back()
    {
        Navigation.NavigateTo("/Projects");
    }
}