@page "/ProjectMembers/{ProjectId:int}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject DialogService DialogService
@inject IProject m_Project
@inject NavigationManager Navigation

<Message @ref="notificationComponent" />

<PageTitle>Members List</PageTitle>

<div class="container-fluid">

    <!-- HEADER -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-header">
                <div class="row align-items-center">

                    <div class="col-lg-9">
                        <div class="d-flex align-items-center">
                            <div class="header-icon me-4">
                                <div class="icon-circle bg-gradient-primary">
                                    <i class="fas fa-users text-white"></i>
                                </div>
                            </div>

                            <div class="header-content">
                                <h1 class="display-6 fw-bold mb-2">
                                    Project Members

                                    @if (IsConfirmed)
                                    {
                                        <span class="ms-3 text-danger fs-6 fw-normal">
                                            (The project is locked. You can not add or remove members.)
                                        </span>
                                    }
                                </h1>

                                <div class="header-meta">
                                    <div class="d-flex flex-wrap gap-3">

                                        <div class="meta-item">
                                            <i class="fas fa-database text-primary me-1"></i>
                                            <span>Total: <strong>@members.Count()</strong></span>
                                        </div>

                                        <div class="meta-item">
                                            <i class="fas fa-home text-success me-1"></i>
                                            <span>@ProjectName</span>
                                        </div>
                                        

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ACTION -->
                    <div class="col-lg-3 text-end">
                        <RadzenButton Text="Add Member"
                                      Icon="add_circle_outline"
                                      Click="AddNew"
                                      Disabled="@IsConfirmed"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Large" />
                                      
                        <RadzenButton Text="Back"
                                      Icon="arrow_back"
                                      Size="ButtonSize.Large"
                                      Click="Back"
                                      ButtonStyle="ButtonStyle.Light"
                                      class="ms-2" />
                    </div>

                </div>

                <div class="row mt-4">
                    <div class="col-12">
                        <div class="header-description">
                            <p class="lead mb-0">
                                <i class="fas fa-info-circle me-2"></i>
                                Manage all members from here.
                            </p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- GRID -->
    <RadzenDataGrid Data="@members" TItem="ProjectMember"
                    PageSize="10"
                    AllowPaging="true"
                    AllowSorting="true">

        <Columns>

            <RadzenDataGridColumn Title="Membership No">
                <Template Context="m">
                    @m.EkotaMember.MembershipNo
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Title="Name">
                <Template Context="m">
                    @m.EkotaMember.Name
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Title="Mobile">
                <Template Context="m">
                    @m.EkotaMember.MobileNumber
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Title="Actions" Width="100px">
                <Template Context="item">
                    <RadzenButton Icon="delete"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Disabled="@IsConfirmed"
                                  Size="ButtonSize.Small"
                                  Click="() => ConfirmDelete(item.Id)" />
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>

</div>

<!-- ✅ MODAL -->
@if (showModal)
{
    <div class="modal" style="display:block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h4>Add Members</h4>
                </div>

                <div class="modal-body">

                    <div class="card p-3 shadow-sm">
                        <RadzenDropDown TValue="IEnumerable<int>"
                                        @bind-Value="SelectedMemberIds"
                                        Data="@AvailableMembers"
                                        TextProperty="Name"
                                        ValueProperty="Id"
                                        Placeholder="Search Members..."
                                        Multiple="true"
                                        AllowFiltering="true"
                                        AllowClear="true"
                                        Chips="true"
                                        Style="width:100%" />
                    </div>

                </div>

                <div class="modal-footer">
                    <RadzenButton Text="Save"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Type="submit"
                                  Class="me-2" />

                    <RadzenButton Text="Cancel"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="CloseModal" />
                </div>

            </div>
        </div>
    </div>
}

<!-- CSS -->
<style>
    .dashboard-header {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

    .header-meta .meta-item {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background: rgba(0,0,0,0.03);
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .header-description {
        padding-top: 1rem;
        border-top: 1px solid rgba(0,0,0,0.1);
        color: #4a5568;
    }
</style>

@code {

    [Parameter] public int ProjectId { get; set; }

    private IList<ProjectMember> members = new List<ProjectMember>();
    private IList<UniqueMemberDTO> AvailableMembers = new List<UniqueMemberDTO>();

    private IEnumerable<int> SelectedMemberIds = new List<int>();

    private string ProjectName = string.Empty;

    private bool showModal = false;
    private bool IsConfirmed = false;

    private Message notificationComponent;

    protected override async Task OnInitializedAsync()
    {
        IsConfirmed = m_Project.IsConfirmThisProject(ProjectId);
        await LoadData();
    }

    private async Task LoadData()
    {
        members = await m_Project.GetProjectMembers(ProjectId);
        ProjectName = m_Project.GetProjectName(ProjectId);
    }

    private async Task AddNew()
    {
        AvailableMembers = await m_Project.GetUniqueProjectMembers(ProjectId);
        SelectedMemberIds = new List<int>();
        showModal = true;
        
    }
    
    private void Back()
    {
        Navigation.NavigateTo("/Projects");
    }

    private async Task SaveMembers()
    {
        if (!SelectedMemberIds.Any())
        {
            notificationComponent.Show("Warning", "Please select at least one member", NotificationSeverity.Warning);
            return;
        }

        await m_Project.AddProjectMembers(ProjectId, SelectedMemberIds.ToList());

        notificationComponent.Show("Success", "Members added successfully", NotificationSeverity.Success);

        await LoadData();

        showModal = false;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task ConfirmDelete(int id)
    {
        var confirmed = await DialogService.Confirm("Delete this member?", "Confirm");

        if (confirmed == true)
        {
            m_Project.ProjectMemberDelete(id);

            notificationComponent.Show("Deleted", "Member deleted successfully", NotificationSeverity.Error);

            await LoadData();
        }
    }
}