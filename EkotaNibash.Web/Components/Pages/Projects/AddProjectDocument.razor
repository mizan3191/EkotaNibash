@page "/AddProjectDocument/{ProjectId:int}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject IProject m_Document
@inject NavigationManager Navigation
@inject DialogService DialogService

<Message @ref="notificationComponent" />

<PageTitle>Upload Project Document</PageTitle>

<div class="container-fluid">

    <!-- HEADER -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-header">
                <div class="d-flex justify-content-between align-items-center">

                    <h3 class="fw-bold">
                       📤 Upload Document
                    </h3>

                    <div>
                        <RadzenButton Text="Back"
                                      Icon="arrow_back"
                                      Click="@(() => Navigation.NavigateTo($"/ProjectDocuments/{ProjectId}"))"
                                      ButtonStyle="ButtonStyle.Light" />
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- FORM -->
    <EditForm Model="document" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="card shadow-sm border-0">
            <div class="card-body">

                <ValidationSummary class="alert alert-danger" />

                <div class="row g-3">

                    <!-- NAME -->
                    <div class="col-md-4">
                        <RadzenLabel Text="Document Name *" />
                        <RadzenTextBox @bind-Value="document.DocumentName"
                                       Class="w-100" />
                    </div>

                    <!-- DATE -->
                    <div class="col-md-4">
                        <RadzenLabel Text="Document Date" />
                        <RadzenDatePicker @bind-Value="document.DocumentDate"
                                          Class="w-100" />
                    </div>

                    <!-- DESCRIPTION -->
                    <div class="col-12">
                        <RadzenLabel Text="Description" />
                        <RadzenTextArea @bind-Value="document.Description"
                                        Rows="3"
                                        Class="w-100" />
                    </div>

                    <!-- FILE -->
                    <div class="col-12">

                        <RadzenLabel Text="Upload File *" />

                        @if (string.IsNullOrEmpty(uploadedFileName))
                        {
                            <InputFile OnChange="OnFileChange" />
                        }
                        else
                        {
                            <div class="border p-2 d-flex justify-content-between">
                                <span>@uploadedFileName (@(uploadedFileSize / 1024) KB)</span>
                                <RadzenButton Icon="close"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Click="ClearFile" />
                            </div>
                        }

                    </div>

                </div>

                <!-- BUTTON -->
                <div class="mt-4 text-end">
                    <RadzenButton Text="Cancel"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="Cancel"
                                  class="me-2" />

                    <RadzenButton Text="Save"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Type="submit" />
                </div>

            </div>
        </div>
    </EditForm>
</div>


<!-- ✅ SAME CSS -->
<style>
    .dashboard-header {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

    .header-meta .meta-item {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background: rgba(0,0,0,0.03);
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .header-description {
        padding-top: 1rem;
        border-top: 1px solid rgba(0,0,0,0.1);
        color: #4a5568;
    }
</style>


@code {

    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int Id { get; set; }

    private ProjectDocument document = new();
  
    private string uploadedFileName = "";
    private long uploadedFileSize;
    private byte[] uploadedBytes;

    private Message notificationComponent;

    protected override void OnInitialized()
    {
        document.ProjectId = ProjectId;
        document.DocumentDate = DateTime.Today;
    }

    private async Task OnFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;

        uploadedFileName = file.Name;
        uploadedFileSize = file.Size;

        using var stream = file.OpenReadStream(7 * 1024 * 1024);
        using var ms = new MemoryStream();

        await stream.CopyToAsync(ms);
        uploadedBytes = ms.ToArray();

        if (!document.IsFileValid(file.Name, uploadedBytes, Path.GetExtension(file.Name)))
        {
            await DialogService.Alert("Invalid file type!", "Error");
            ClearFile();
        }
    }

    private void ClearFile()
    {
        uploadedFileName = "";
        uploadedBytes = null;
    }

    private async Task HandleSubmit()
    {
        try
        {
            // ✅ FILE VALIDATION
            if (uploadedBytes == null || uploadedBytes.Length == 0)
            {
                await DialogService.Alert("Please upload a file before saving.", "Validation Error");
                return;
            }

            if (!string.IsNullOrEmpty(uploadedFileName))
            {
                document.File = uploadedBytes;
                document.FileName = uploadedFileName;
                document.FileType = Path.GetExtension(uploadedFileName);
            }

            document.ProjectId = ProjectId;

            // You can rename this method later (Create/Update)
            var result = m_Document.ProjectDocumentCreate(document);

            if (result > 0)
            {
                notificationComponent.Show("Success", "Saved successfully", NotificationSeverity.Success);
                Navigation.NavigateTo($"/ProjectDocuments/{ProjectId}");
            }
        }
        catch (Exception ex)
        {
            await DialogService.Alert(ex.Message, "Error");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo($"/ProjectDocuments/{ProjectId}");
    }
}