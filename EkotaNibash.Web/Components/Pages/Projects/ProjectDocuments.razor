@page "/ProjectDocuments/{ProjectId:int}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject IProject m_Document
@inject NavigationManager Navigation
@inject DialogService DialogService
@inject IJSRuntime JSRuntime

<Message @ref="notificationComponent" />

<PageTitle>Project Documents</PageTitle>

<div class="container-fluid">

    <!-- HEADER -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-header">
                <div class="row align-items-center">

                    <div class="col-lg-6">
                        <div class="d-flex align-items-center">
        
                            <!-- ICON -->
                            <div class="header-icon me-4">
                                <div class="icon-circle bg-gradient-primary d-flex align-items-center justify-content-center"
                                     style="width:60px; height:60px; border-radius:50%;">
                 
                                    <i class="fas fa-folder-open text-white" style="font-size:24px;"></i>
            
                                </div>
                            </div>

                            <!-- CONTENT -->
                            <div class="header-content">
                                <h3 class="fw-bold mb-1">Project Documents</h3>

                                <div class="header-meta">
                                    <div class="d-flex flex-wrap gap-3">

                                        <div class="meta-item">
                                            <i class="fas fa-database text-primary me-1"></i>
                                            <span>Total: <strong>@documents.Count()</strong></span>
                                        </div>

                                        <div class="meta-item">
                                            <i class="fas fa-home text-success me-1"></i>
                                            <span>@ProjectName</span>
                                        </div>

                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ACTION -->
                    <div class="col-lg-6 text-end">
                        <RadzenButton Text="Upload"
                                      Icon="upload"
                                      Click="OpenPopup"
                                      Size="ButtonSize.Large"
                                      ButtonStyle="ButtonStyle.Primary" />

                        <RadzenButton Text="Back"
                                      Icon="arrow_back"
                                      Size="ButtonSize.Large"
                                      Click="Back"
                                      ButtonStyle="ButtonStyle.Light"
                                      class="ms-2" />
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- SEARCH -->
    <div class="mb-3">
        <RadzenTextBox @bind-Value="search"
                       Placeholder="Search..."
                       Style="width:300px"
                       @oninput="OnSearch" />
    </div>

    <!-- GRID -->
    <RadzenDataGrid Data="@FilteredDocuments" TItem="ProjectDocumentListDTO"
                    PageSize="10"
                    AllowPaging="true">

        <Columns>

            <RadzenDataGridColumn Title="Date">
                <Template Context="doc">
                    @(doc.DocumentDate?.ToString("dd-MMM-yyyy"))
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Property="DocumentName" Title="Name" />
            <RadzenDataGridColumn Property="FileType" Title="Type" />
            <RadzenDataGridColumn Property="Description" Title="Description" />

            <RadzenDataGridColumn Title="Actions">
                <Template Context="doc">

                    <RadzenButton Icon="visibility"
                                  ButtonStyle="ButtonStyle.Info"
                                  Click="() => View(doc.Id)" />

                    <RadzenButton Icon="download"
                                  ButtonStyle="ButtonStyle.Success"
                                  Click="() => Download(doc.Id)" />

                    <RadzenButton Icon="delete"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Click="() => Delete(doc.Id)" />

                </Template>
            </RadzenDataGridColumn>

        </Columns>

    </RadzenDataGrid>

</div>

<!-- ✅ POPUP -->
@if (showModal)
{
    <div class="modal" style="display:block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h4>Upload Document</h4>
                </div>

                <EditForm Model="@document" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="modal-body">

                        <ValidationSummary class="alert alert-danger" />

                        <div class="row g-3">

                            <!-- NAME -->
                            <div class="col-md-4">
                                <RadzenLabel Text="Document Name *" />
                                <RadzenTextBox @bind-Value="document.DocumentName"
                                               Class="w-100" />
                            </div>

                            <!-- DATE -->
                            <div class="col-md-4">
                                <RadzenLabel Text="Date" />
                                <RadzenDatePicker @bind-Value="document.DocumentDate"
                                                  Class="w-100" />
                            </div>

                            <!-- DESCRIPTION -->
                            <div class="col-12">
                                <RadzenLabel Text="Description" />
                                <RadzenTextArea @bind-Value="document.Description"
                                                Class="w-100" />
                            </div>

                            <!-- FILE -->
                            <div class="col-12">

                                <RadzenLabel Text="Upload File *" />

                                @if (string.IsNullOrEmpty(uploadedFileName))
                                {
                                    <InputFile OnChange="OnFileChange" />
                                }
                                else
                                {
                                    <div class="border p-2 d-flex justify-content-between">
                                        <span>@uploadedFileName (@(uploadedFileSize / 1024) KB)</span>

                                        <RadzenButton Icon="close"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Click="ClearFile" />
                                    </div>
                                }

                            </div>

                        </div>

                    </div>

                    <div class="modal-footer">
                        <RadzenButton Text="Save"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Type="submit"
                                      Class="me-2" />

                        <RadzenButton Text="Cancel"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="CloseModal" />
                    </div>

                </EditForm>

            </div>
        </div>
    </div>
}


<!-- CSS -->
<style>
    .dashboard-header {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

    .header-meta .meta-item {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background: rgba(0,0,0,0.03);
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .header-description {
        padding-top: 1rem;
        border-top: 1px solid rgba(0,0,0,0.1);
        color: #4a5568;
    }
</style>


@code {

    [Parameter] public int ProjectId { get; set; }

    private List<ProjectDocumentListDTO> documents = new();
    private List<ProjectDocumentListDTO> FilteredDocuments = new();

    private string search = "";
    private string ProjectName = string.Empty;

    private bool showModal = false;

    private ProjectDocument document = new();

    private string uploadedFileName = "";
    private long uploadedFileSize;
    private byte[] uploadedBytes;

    private Message notificationComponent;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        documents = m_Document.GetAllProjectDocuments(ProjectId).ToList();
        FilteredDocuments = documents;
        ProjectName = m_Document.GetProjectName(ProjectId);
    }

    private void OpenPopup()
    {
        document = new ProjectDocument
        {
            ProjectId = ProjectId,
            DocumentDate = DateTime.Today
        };

        ClearFile();
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void OnSearch(ChangeEventArgs e)
    {
        search = e.Value?.ToString();

        FilteredDocuments = documents.Where(x =>
            (x.DocumentName?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (x.Description?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (x.FileType?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList();
    }

    private async Task OnFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;

        uploadedFileName = file.Name;
        uploadedFileSize = file.Size;

        using var stream = file.OpenReadStream(7 * 1024 * 1024);
        using var ms = new MemoryStream();

        await stream.CopyToAsync(ms);
        uploadedBytes = ms.ToArray();

        if (!document.IsFileValid(file.Name, uploadedBytes, Path.GetExtension(file.Name)))
        {
            await DialogService.Alert("Invalid file!", "Error");
            ClearFile();
        }
    }

    private void ClearFile()
    {
        uploadedFileName = "";
        uploadedBytes = null;
    }

    private async Task HandleSubmit()
    {
        if (uploadedBytes == null || uploadedBytes.Length == 0)
        {
            // await DialogService.Alert("Upload file required!", "Validation");
            notificationComponent.Show("Success", "Upload file required!", NotificationSeverity.Error);
            return;
        }

        document.File = uploadedBytes;
        document.FileName = uploadedFileName;
        document.FileType = Path.GetExtension(uploadedFileName);

        m_Document.ProjectDocumentCreate(document);

        showModal = false;
        LoadData();

        notificationComponent.Show("Success", "Saved", NotificationSeverity.Success);
    }

    private async Task Delete(int id)
    {
        var confirm = await DialogService.Confirm("Delete?", "Confirm");

        if (confirm == true)
        {
            m_Document.DeleteDocument(id);
            LoadData();
        }
    }

    private async Task View(int id)
    {
        var doc = m_Document.GetDocument(id);

        if (doc?.File != null)
        {
            var base64 = Convert.ToBase64String(doc.File);
            var mime = GetMimeType(doc.FileName);

            var js = $"window.open('data:{mime};base64,{base64}')";

            await JSRuntime.InvokeVoidAsync("eval", js);
        }
    }

    private async Task Download(int id)
    {
        var doc = m_Document.DownloadDocument(id);

        if (doc?.File != null)
        {
            var base64 = Convert.ToBase64String(doc.File);

            var js = $@"
                var a = document.createElement('a');
                a.href = 'data:application/octet-stream;base64,{base64}';
                a.download = '{doc.FileName}';
                a.click();";

            await JSRuntime.InvokeVoidAsync("eval", js);
        }
    }

    private string GetMimeType(string fileName)
    {
        return Path.GetExtension(fileName).ToLower() switch
        {
            ".pdf" => "application/pdf",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            _ => "application/octet-stream"
        };
    }

    private void Back()
    {
        Navigation.NavigateTo("/Projects");
    }
}