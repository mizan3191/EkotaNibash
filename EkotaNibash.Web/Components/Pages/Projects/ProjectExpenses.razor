@page "/ProjectExpenses/{ProjectId:int}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject DialogService DialogService
@inject NavigationManager Navigation
@inject IProject m_Project

<Message @ref="notificationComponent" />

<div class="container-fluid">

    <!-- ✅ HEADER (Same Design) -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-header">
                <div class="row align-items-center">

                    <div class="col-lg-8">
                        <div class="d-flex align-items-center">

                            <div class="header-icon me-4">
                                <div class="icon-circle bg-gradient-warning">
                                    <i class="fas fa-receipt text-white"></i>
                                </div>
                            </div>

                            <div>
                                <h1 class="display-6 fw-bold mb-2">Project Expenses</h1>

                                @if (expenses != null && expenses.Any())
                                {
                                    var last = expenses.OrderByDescending(x => x.Date).FirstOrDefault();

                                    <div class="header-meta d-flex gap-3">
                                        <div class="meta-item">
                                            <i class="fas fa-list text-primary me-2"></i>
                                            Total: <strong>@expenses.Count()</strong>
                                        </div>

                                        <div class="meta-item">
                                            <i class="fas fa-calendar text-success me-2"></i>
                                            Last:
                                            <strong>@last?.Date.ToString("dd MMM yyyy")</strong>
                                        </div>

                                        <div class="meta-item">
                                            <i class="fas fa-home text-success me-1"></i>
                                            <span>@ProjectName</span>
                                        </div>
                                    </div>
                                }
                            </div>

                        </div>
                    </div>

                    <div class="col-lg-4 text-end">
                        <RadzenButton Text="Add Expense"
                                      Icon="add_circle_outline"
                                      Click="AddNew"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Large" />

                        <RadzenButton Text="Back"
                                      Icon="arrow_back"
                                      Size="ButtonSize.Large"
                                      Click="Back"
                                      ButtonStyle="ButtonStyle.Light"
                                      class="ms-2" />

                        <div class="mt-3 text-end">
                            <div class="text-muted small">Total Expense</div>
                            <div class="h4 fw-bold text-danger">@TotalExpense.ToString("0.00")</div>
                        </div>
                    </div>
                    
                </div>

                <div class="header-description mt-4">
                    <p class="mb-0">
                        <i class="fas fa-info-circle text-info me-2"></i>
                        Track all project expenses and manage financial records easily.
                    </p>
                </div>

            </div>
        </div>
    </div>

    <!-- ✅ SEARCH -->
    <div class="row mb-3">
        <div class="col-md-4">
            <RadzenTextBox @bind-Value="search"
                           Placeholder="Search..."
                           Style="width:100%"
                           @oninput="OnSearch" />
        </div>
    </div>

    <!-- ✅ GRID -->
    <div class="card">
        <div class="card-body p-0">

            <RadzenDataGrid Data="@FilteredExpenses"
                            TItem="ProjectExpenseDetails"
                            AllowPaging="true"
                            PageSize="10">

                <Columns>

                    <RadzenDataGridColumn Property="@nameof(ProjectExpenseDetails.DateFormatted)"
                                          Title="Date"
                                          Width="250px" />

                    <RadzenDataGridColumn Property="@nameof(ProjectExpenseDetails.Amount)"
                                          Title="Amount"
                                          Width="250px" />

                    <RadzenDataGridColumn Title="Description">
                        <Template Context="item">
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <div class="text-truncate" style="max-width:200px;">
                                    @item.Description
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">No description</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn Title="Actions" Width="200px">
                        <Template Context="item">

                            <RadzenButton Icon="edit"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Size="ButtonSize.Medium"
                                          Click="() => Edit(item.Id)" />

                            <RadzenButton Icon="delete"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Size="ButtonSize.Medium"
                                          Click="() => ConfirmDelete(item.Id)" />

                        </Template>
                    </RadzenDataGridColumn>

                </Columns>

            </RadzenDataGrid>

        </div>
    </div>

</div>

<!-- ✅ POPUP (Same as Project Page) -->
@if (showModal)
{
    <div class="modal" style="display:block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h4>@(expense.Id > 0 ? "Edit Expense" : "Add Expense")</h4>
                </div>

                <EditForm Model="@expense" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="modal-body">

                        <div class="row">

                            <div class="col-md-4">
                                <label>Date</label>
                                <RadzenDatePicker @bind-Value="expense.Date" Class="w-100" />
                            </div>

                            <div class="col-md-4">
                                <label>Amount</label>
                                <RadzenNumeric @bind-Value="expense.Amount"
                                               Style="width:100%" />
                            </div>

                            <div class="col-md-12 mt-3">
                                <label>Description</label>
                                <RadzenTextArea @bind-Value="expense.Description"
                                                class="form-control" />
                            </div>

                        </div>

                    </div>

                    <div class="modal-footer">
                        <RadzenButton Text="Save"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Type="submit"
                                      Class="me-2" />

                        <RadzenButton Text="Cancel"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="CloseModal" />
                    </div>

                </EditForm>

            </div>
        </div>
    </div>
}

<!-- ✅ SAME CSS -->
<style>
    .dashboard-header {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .bg-gradient-warning {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .header-meta .meta-item {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background: rgba(0,0,0,0.03);
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .header-description {
        padding-top: 1rem;
        border-top: 1px solid rgba(0,0,0,0.1);
        color: #4a5568;
    }
</style>

@code {

    [Parameter] public int ProjectId { get; set; }

    private IEnumerable<ProjectExpenseDetails> expenses = new List<ProjectExpenseDetails>();
    private IEnumerable<ProjectExpenseDetails> FilteredExpenses = new List<ProjectExpenseDetails>();

    private ProjectExpenseDetails expense = new();
    private bool showModal = false;
    private string search = "";
    private string ProjectName = string.Empty;

    private Message notificationComponent;
    private double TotalExpense => expenses?.Sum(x => x.Amount) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        ProjectName = m_Project.GetProjectName(ProjectId);
    }

    private async Task LoadData()
    {
        expenses = await m_Project.GetAllProjectExpenseDetails(ProjectId);
        FilteredExpenses = expenses;
    }

    private void AddNew()
    {
        expense = new ProjectExpenseDetails
        {
            Date = DateTime.Today,
            ProjectId = ProjectId
        };

        showModal = true;
    }

    private void Edit(int id)
    {
        expense = m_Project.GetProjectExpenseDetails(id);
        showModal = true;
    }

    private async Task HandleSubmit()
    {
        if (expense.Id > 0)
        {
            m_Project.ProjectExpenseDetailsUpdate(expense);
            notificationComponent.Show("Updated", "Expense updated", NotificationSeverity.Success);
        }
        else
        {
            m_Project.ProjectExpenseDetailsCreate(expense);
            notificationComponent.Show("Added", "Expense added", NotificationSeverity.Success);
        }

        await LoadData();
        CloseModal();
    }

    private async Task ConfirmDelete(int id)
    {
        var confirm = await DialogService.Confirm("Delete this expense?", "Confirm");

        if (confirm == true)
        {
            m_Project.ProjectExpenseDetailsDelete(id);
            await LoadData();
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }
    
    private void Back()
    {
        Navigation.NavigateTo("/Projects");
    }

    private void OnSearch(ChangeEventArgs e)
    {
        search = e.Value?.ToString();

        if (string.IsNullOrWhiteSpace(search))
        {
            FilteredExpenses = expenses;
        }
        else
        {
            FilteredExpenses = expenses.Where(x =>
                (!string.IsNullOrEmpty(x.Description) &&
                 x.Description.Contains(search, StringComparison.OrdinalIgnoreCase))
            ).ToList();
        }
    }
}